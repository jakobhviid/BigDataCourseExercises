apiVersion: v1
clusters:
- cluster:
    certificate-authority-data: 
    server: https://tribus0.uvm.sdu.dk:6443
  name: sdu
contexts:
- context:
    cluster: sdu
    namespace: {{ team }}
    user: sdu-{{ team }}
  name: sdu-{{ team }}
current-context: sdu-{{ team }}
kind: Config
preferences: {}
users:
- name: sdu-{{ team }}
  user:
    client-certificate-data: {{ client_certificate_data }}
    client-key-data: {{ client_key_data }}
